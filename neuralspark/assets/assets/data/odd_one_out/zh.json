[
  {"id":"ooo_e01","difficulty":"easy","items":["苹果","香蕉","胡萝卜","葡萄"],"oddIndex":2,"groupingRule":"除胡萝卜外都是水果（胡萝卜是蔬菜）"},
  {"id":"ooo_e02","difficulty":"easy","items":["狗","猫","鲨鱼","兔子"],"oddIndex":2,"groupingRule":"除鲨鱼外都是陆地动物（鲨鱼生活在水中）"},
  {"id":"ooo_e03","difficulty":"easy","items":["钢琴","吉他","鼓","绘画"],"oddIndex":3,"groupingRule":"除绘画外都是乐器（绘画是视觉艺术）"},
  {"id":"ooo_e04","difficulty":"easy","items":["玫瑰","郁金香","橡树","雏菊"],"oddIndex":2,"groupingRule":"除橡树外都是花（橡树是树木）"},
  {"id":"ooo_e05","difficulty":"easy","items":["圆形","正方形","三角形","立方体"],"oddIndex":3,"groupingRule":"除立方体外都是平面图形（立方体是立体图形）"},
  {"id":"ooo_e06","difficulty":"easy","items":["水星","金星","月亮","火星"],"oddIndex":2,"groupingRule":"除月亮外都是行星（月亮是卫星）"},
  {"id":"ooo_e07","difficulty":"easy","items":["锤子","螺丝刀","扳手","枕头"],"oddIndex":3,"groupingRule":"除枕头外都是工具（枕头是寝具）"},
  {"id":"ooo_e08","difficulty":"easy","items":["牛奶","果汁","面包","水"],"oddIndex":2,"groupingRule":"除面包外都是饮料（面包是食物）"},
  {"id":"ooo_e09","difficulty":"easy","items":["红色","蓝色","甜","绿色"],"oddIndex":2,"groupingRule":"除甜以外都是颜色（甜是味觉）"},
  {"id":"ooo_e10","difficulty":"easy","items":["椅子","桌子","台灯","自行车"],"oddIndex":3,"groupingRule":"除自行车外都是家具（自行车是交通工具）"},
  {"id":"ooo_e11","difficulty":"easy","items":["鹰","麻雀","企鹅","知更鸟"],"oddIndex":2,"groupingRule":"除企鹅外都能飞（企鹅是不会飞的鸟）"},
  {"id":"ooo_e12","difficulty":"easy","items":["网球","足球","国际象棋","篮球"],"oddIndex":2,"groupingRule":"除国际象棋外都是体育运动（国际象棋是棋盘游戏）"},
  {"id":"ooo_e13","difficulty":"easy","items":["衬衫","裤子","帽子","冰箱"],"oddIndex":3,"groupingRule":"除冰箱外都是衣物（冰箱是家电）"},
  {"id":"ooo_e14","difficulty":"easy","items":["一月","三月","夏天","七月"],"oddIndex":2,"groupingRule":"除夏天外都是月份（夏天是季节）"},
  {"id":"ooo_e15","difficulty":"easy","items":["小提琴","长笛","大提琴","小号"],"oddIndex":3,"groupingRule":"除小号外都是弦乐器或木管乐器（小号是铜管乐器）"},
  {"id":"ooo_e16","difficulty":"easy","items":["三文鱼","金枪鱼","螃蟹","鳟鱼"],"oddIndex":2,"groupingRule":"除螃蟹外都是鱼类（螃蟹是甲壳类）"},
  {"id":"ooo_e17","difficulty":"easy","items":["地球","木星","太阳","土星"],"oddIndex":2,"groupingRule":"除太阳外都是行星（太阳是恒星）"},
  {"id":"ooo_e18","difficulty":"easy","items":["金","银","铁","钻石"],"oddIndex":3,"groupingRule":"除钻石外都是金属（钻石是宝石）"},
  {"id":"ooo_e19","difficulty":"easy","items":["蚂蚁","蜜蜂","蜘蛛","蝴蝶"],"oddIndex":2,"groupingRule":"除蜘蛛外都是昆虫（蜘蛛是蛛形纲）"},
  {"id":"ooo_e20","difficulty":"easy","items":["铅笔","钢笔","橡皮","马克笔"],"oddIndex":2,"groupingRule":"除橡皮外都是书写工具（橡皮是擦除工具）"},
  {"id":"ooo_e21","difficulty":"easy","items":["大象","鲸鱼","狮子","熊"],"oddIndex":1,"groupingRule":"除鲸鱼外都是陆地哺乳动物（鲸鱼是海洋哺乳动物）"},
  {"id":"ooo_e22","difficulty":"easy","items":["胡萝卜","土豆","草莓","洋葱"],"oddIndex":2,"groupingRule":"除草莓外都是蔬菜（草莓是水果）"},

  {"id":"ooo_m01","difficulty":"medium","items":["脑","风暴","信任","波","洗"],"oddIndex":2,"groupingRule":"能与「脑」组成复合词的（脑风暴→头脑风暴、脑波、洗脑）除外是信任（脑信任不是常见词）"},
  {"id":"ooo_m02","difficulty":"medium","items":["冰","火","石","水","冷"],"oddIndex":4,"groupingRule":"冰、火、石、水都是表示物质的名词，而冷是形容词（表示状态）"},
  {"id":"ooo_m03","difficulty":"medium","items":["书","灯","雨","家","虫"],"oddIndex":2,"groupingRule":"都能跟在「book」后面组成复合词（booklight、bookhouse、bookworm）除外是雨（Rain）"},
  {"id":"ooo_m04","difficulty":"medium","items":["分","秒","光","时","日"],"oddIndex":2,"groupingRule":"除光以外都是时间单位（光是电磁辐射）"},
  {"id":"ooo_m05","difficulty":"medium","items":["三月","五月","八月","十一月","春天"],"oddIndex":4,"groupingRule":"除春天外都是月份（春天是季节）"},
  {"id":"ooo_m06","difficulty":"medium","items":["蝙蝠","鹤","树皮","海豹","龟"],"oddIndex":2,"groupingRule":"蝙蝠、鹤、海豹、龟都有动物和非动物的多重含义，树皮没有动物的含义"},
  {"id":"ooo_m07","difficulty":"medium","items":["蜡烛","灯","月亮","烤箱","星星"],"oddIndex":3,"groupingRule":"除烤箱外都发光（烤箱主要产生热量）"},
  {"id":"ooo_m08","difficulty":"medium","items":["桥","公路","隧道","塔","小路"],"oddIndex":3,"groupingRule":"除塔以外都连接两个地方（塔矗立在一处）"},
  {"id":"ooo_m09","difficulty":"medium","items":["低语","呐喊","嘟囔","书写","吼叫"],"oddIndex":3,"groupingRule":"除书写外都是用声音传达的方式（书写是视觉传达）"},
  {"id":"ooo_m10","difficulty":"medium","items":["棉","丝","羊毛","皮革","尼龙"],"oddIndex":4,"groupingRule":"除尼龙外都是天然材料（尼龙是合成材料）"},
  {"id":"ooo_m11","difficulty":"medium","items":["钟","日历","尺子","日晷","沙漏"],"oddIndex":2,"groupingRule":"除尺子外都测量时间（尺子测量长度）"},
  {"id":"ooo_m12","difficulty":"medium","items":["咳嗽","打喷嚏","打哈欠","眨眼","打嗝"],"oddIndex":3,"groupingRule":"除眨眼外都是涉及气流突然运动的非自主反射（眨眼是眼睑动作）"},
  {"id":"ooo_m13","difficulty":"medium","items":["锚","潜水艇","珊瑚","海藻","风筝"],"oddIndex":4,"groupingRule":"除风筝外都在水下（风筝在空中飞）"},
  {"id":"ooo_m14","difficulty":"medium","items":["钢琴","风琴","竖琴","手风琴","鼓"],"oddIndex":4,"groupingRule":"除鼓以外都有琴键或琴弦（鼓是打击乐器）"},
  {"id":"ooo_m15","difficulty":"medium","items":["透镜","镜子","窗户","墙","棱镜"],"oddIndex":3,"groupingRule":"除墙以外都让光通过或改变光的方向（墙阻挡光）"},
  {"id":"ooo_m16","difficulty":"medium","items":["护士","医生","教师","牙医","外科医生"],"oddIndex":2,"groupingRule":"除教师外都是医疗专业人员（教师属于教育行业）"},
  {"id":"ooo_m17","difficulty":"medium","items":["影子","回声","倒影","照片","海市蜃楼"],"oddIndex":3,"groupingRule":"除照片外都是源消失就会消失的临时再现（照片是永久记录）"},
  {"id":"ooo_m18","difficulty":"medium","items":["手套","袜子","戒指","鞋","靴子"],"oddIndex":2,"groupingRule":"除戒指外都是穿在手脚上的衣物（戒指是首饰不是衣物）"},
  {"id":"ooo_m19","difficulty":"medium","items":["盐","糖","胡椒","面粉","肉桂"],"oddIndex":3,"groupingRule":"除面粉外都是调味料或香料（面粉是烘焙原料）"},
  {"id":"ooo_m20","difficulty":"medium","items":["羽毛","气球","烟","锚","泡泡"],"oddIndex":3,"groupingRule":"除锚以外都是轻的、能浮起的东西（锚很重会下沉）"},
  {"id":"ooo_m21","difficulty":"medium","items":["刀","剪刀","锯","锤子","剃刀"],"oddIndex":3,"groupingRule":"除锤子外都是切割工具（锤子是敲打工具）"},
  {"id":"ooo_m22","difficulty":"medium","items":["河流","溪流","湖泊","瀑布","池塘"],"oddIndex":3,"groupingRule":"除瀑布外都有水平的水面（瀑布是垂直流水）"},

  {"id":"ooo_h01","difficulty":"hard","items":["心","承诺","记录","沉默","波浪","冰"],"oddIndex":2,"groupingRule":"都能被「打破」的事物（打破沉默、打破心、打破波浪、打破冰）除外是记录（记录是「打破」但意为超越/刷新）"},
  {"id":"ooo_h02","difficulty":"hard","items":["河流","鼻子","故事","时钟","丝袜","谈话"],"oddIndex":3,"groupingRule":"都能「跑」的事物（河流奔跑、鼻子流涕、故事发展、丝袜抽丝、谈话进行）除外是时钟（时钟是「滴答」走的）"},
  {"id":"ooo_h03","difficulty":"hard","items":["土豆","电池","云","想法","沙发","闪电"],"oddIndex":4,"groupingRule":"都与「电」或「能量」有关的事物除外是沙发（沙发没有电荷关联）"},
  {"id":"ooo_h04","difficulty":"hard","items":["镜子","湖","地板","眼睛","钻石","盾牌"],"oddIndex":2,"groupingRule":"都有反射面的事物除外是地板（地板通常不反光）"},
  {"id":"ooo_h05","difficulty":"hard","items":["邮票","护照","车票","硬币","信","书签"],"oddIndex":5,"groupingRule":"都用于旅行或交易的事物除外是书签（书签用于阅读）"},
  {"id":"ooo_h06","difficulty":"hard","items":["梯子","事业","山","温度","楼梯","电梯"],"oddIndex":5,"groupingRule":"都是逐步攀升的事物除外是电梯（电梯无需逐步就能上升）"},
  {"id":"ooo_h07","difficulty":"hard","items":["蜡烛","电池","储蓄","耐心","绳子","引线"],"oddIndex":4,"groupingRule":"都能「耗尽」的事物除外是绳子（绳子磨损或断裂，但不耗尽）"},
  {"id":"ooo_h08","difficulty":"hard","items":["桥","牙齿","空隙","沉默","栅栏","墙"],"oddIndex":4,"groupingRule":"都能被「填补」的事物除外是栅栏（栅栏围合但不填补）"},
  {"id":"ooo_h09","difficulty":"hard","items":["谣言","火","疾病","油漆","黄油","新闻"],"oddIndex":3,"groupingRule":"都能自发「传播」的事物除外是油漆（油漆是被涂抹的，不自发扩散）"},
  {"id":"ooo_h10","difficulty":"hard","items":["鸡蛋","秘密","密码","黎明","保险箱","核桃"],"oddIndex":3,"groupingRule":"都能被「破解」的事物除外是黎明（黎明是「破晓」，不是被破解）"},
  {"id":"ooo_h11","difficulty":"hard","items":["钟","鼓","警报","雷","哨子","枕头"],"oddIndex":5,"groupingRule":"都发出响亮声音的事物除外是枕头（枕头柔软无声）"},
  {"id":"ooo_h12","difficulty":"hard","items":["钥匙","密码","门","地图","线索","谜语"],"oddIndex":3,"groupingRule":"都能「打开」某物的事物除外是地图（地图引导方向但不打开什么）"},
  {"id":"ooo_h13","difficulty":"hard","items":["种子","想法","谣言","水晶","投资","孩子"],"oddIndex":3,"groupingRule":"都能「成长」的事物除外是水晶（水晶是「形成」的，日常不说「成长」）"},
  {"id":"ooo_h14","difficulty":"hard","items":["线","情节","河流","争论","耐心","路"],"oddIndex":4,"groupingRule":"都能被「追踪」的事物除外是耐心（耐心是磨练的，不是追踪的）"},
  {"id":"ooo_h15","difficulty":"hard","items":["风","笑话","发条","手表","胶带","时钟"],"oddIndex":1,"groupingRule":"都能被「上紧/卷起」的事物除外是笑话（笑话是讲的，不是卷的）"},
  {"id":"ooo_h16","difficulty":"hard","items":["玻璃","心","规则","记录","鸡蛋","承诺"],"oddIndex":2,"groupingRule":"都是易碎的事物除外是规则（规则被「打破」但本身不脆弱）"},
  {"id":"ooo_h17","difficulty":"hard","items":["雪","雾","尘","寂静","黑暗","毯子"],"oddIndex":5,"groupingRule":"都是笼罩一片区域的无形现象除外是毯子（毯子是有形的织物）"},
  {"id":"ooo_h18","difficulty":"hard","items":["锚","根","传统","基础","习惯","风筝"],"oddIndex":5,"groupingRule":"都是使事物稳定的除外是风筝（风筝是飞走的）"},
  {"id":"ooo_h19","difficulty":"hard","items":["海绵","学生","土壤","心灵","纸","镜子"],"oddIndex":5,"groupingRule":"都能「吸收」的事物除外是镜子（镜子反射而不吸收）"},
  {"id":"ooo_h20","difficulty":"hard","items":["火山","脾气","气球","泡泡","烟花","种子"],"oddIndex":5,"groupingRule":"都能「爆发」的事物除外是种子（种子发芽但不爆发）"},
  {"id":"ooo_h21","difficulty":"hard","items":["网","蛛网","陷阱","迷宫","拼图","桥"],"oddIndex":5,"groupingRule":"都用于捕捉或使人困惑的事物除外是桥（桥连接而不困住）"},
  {"id":"ooo_h22","difficulty":"hard","items":["潮汐","时尚","命运","心情","季节","砖"],"oddIndex":5,"groupingRule":"都是周期性变化的事物除外是砖（砖是静态不变的）"}
]
