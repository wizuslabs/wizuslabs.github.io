  {"id":"ooo_e15","difficulty":"easy","items":["小提琴","長笛","大提琴","小號"],"oddIndex":3,"groupingRule":"除小號外都是弦樂器或木管樂器（小號是銅管樂器）"},
  {"id":"ooo_e16","difficulty":"easy","items":["鮭魚","鮪魚","螃蟹","鱒魚"],"oddIndex":2,"groupingRule":"除螃蟹外都是魚類（螃蟹是甲殼類）"},
  {"id":"ooo_e17","difficulty":"easy","items":["地球","木星","太陽","土星"],"oddIndex":2,"groupingRule":"除太陽外都是行星（太陽是恆星）"},
  {"id":"ooo_e18","difficulty":"easy","items":["金","銀","鐵","鑽石"],"oddIndex":3,"groupingRule":"除鑽石外都是金屬（鑽石是寶石）"},
  {"id":"ooo_e19","difficulty":"easy","items":["螞蟻","蜜蜂","蜘蛛","蝴蝶"],"oddIndex":2,"groupingRule":"除蜘蛛外都是昆蟲（蜘蛛是蛛形綱）"},
  {"id":"ooo_e20","difficulty":"easy","items":["鉛筆","鋼筆","橡皮擦","麥克筆"],"oddIndex":2,"groupingRule":"除橡皮擦外都是書寫工具（橡皮擦是擦除工具）"},
  {"id":"ooo_e21","difficulty":"easy","items":["大象","鯨魚","獅子","熊"],"oddIndex":1,"groupingRule":"除鯨魚外都是陸地哺乳動物（鯨魚是海洋哺乳動物）"},
  {"id":"ooo_e22","difficulty":"easy","items":["胡蘿蔔","馬鈴薯","草莓","洋蔥"],"oddIndex":2,"groupingRule":"除草莓外都是蔬菜（草莓是水果）"},

  {"id":"ooo_m01","difficulty":"medium","items":["腦","風暴","信任","波","洗"],"oddIndex":2,"groupingRule":"能與「腦」組成複合詞的（腦風暴→腦力激盪、腦波、洗腦）除外是信任（腦信任不是常見詞）"},
  {"id":"ooo_m02","difficulty":"medium","items":["冰","火","石","水","冷"],"oddIndex":4,"groupingRule":"冰、火、石、水都是表示物質的名詞，而冷是形容詞（表示狀態）"},
  {"id":"ooo_m03","difficulty":"medium","items":["書","燈","雨","架","蟲"],"oddIndex":2,"groupingRule":"能與「書」組成複合詞的（書燈、書架、書蟲）除外是雨（書雨不是常見詞）"},
  {"id":"ooo_m04","difficulty":"medium","items":["分","秒","光","時","日"],"oddIndex":2,"groupingRule":"除光以外都是時間單位（光是電磁輻射）"},
  {"id":"ooo_m05","difficulty":"medium","items":["三月","五月","八月","十一月","春天"],"oddIndex":4,"groupingRule":"除春天外都是月份（春天是季節）"},
  {"id":"ooo_m06","difficulty":"medium","items":["蝙蝠","鶴","樹皮","海豹","龜"],"oddIndex":2,"groupingRule":"蝙蝠、鶴、海豹、龜都有動物和非動物的多重含義，樹皮沒有動物的含義"},
  {"id":"ooo_m07","difficulty":"medium","items":["蠟燭","燈","月亮","烤箱","星星"],"oddIndex":3,"groupingRule":"除烤箱外都發光（烤箱主要產生熱量）"},
  {"id":"ooo_m08","difficulty":"medium","items":["橋","公路","隧道","塔","小路"],"oddIndex":3,"groupingRule":"除塔以外都連接兩個地方（塔矗立在一處）"},
  {"id":"ooo_m09","difficulty":"medium","items":["低語","吶喊","嘟囔","書寫","吼叫"],"oddIndex":3,"groupingRule":"除書寫外都是用聲音傳達的方式（書寫是視覺傳達）"},
  {"id":"ooo_m10","difficulty":"medium","items":["棉","絲","羊毛","皮革","尼龍"],"oddIndex":4,"groupingRule":"除尼龍外都是天然材料（尼龍是合成材料）"},
  {"id":"ooo_m11","difficulty":"medium","items":["鐘","日曆","尺","日晷","沙漏"],"oddIndex":2,"groupingRule":"除尺外都測量時間（尺測量長度）"},
  {"id":"ooo_m12","difficulty":"medium","items":["咳嗽","打噴嚏","打哈欠","眨眼","打嗝"],"oddIndex":3,"groupingRule":"除眨眼外都是涉及氣流突然運動的非自主反射（眨眼是眼瞼動作）"},
  {"id":"ooo_m13","difficulty":"medium","items":["錨","潛水艇","珊瑚","海藻","風箏"],"oddIndex":4,"groupingRule":"除風箏外都在水下（風箏在空中飛）"},
  {"id":"ooo_m14","difficulty":"medium","items":["鋼琴","風琴","豎琴","手風琴","鼓"],"oddIndex":4,"groupingRule":"除鼓以外都有琴鍵或琴弦（鼓是打擊樂器）"},
  {"id":"ooo_m15","difficulty":"medium","items":["透鏡","鏡子","窗戶","牆","稜鏡"],"oddIndex":3,"groupingRule":"除牆以外都讓光通過或改變光的方向（牆阻擋光）"},
  {"id":"ooo_m16","difficulty":"medium","items":["護士","醫生","教師","牙醫","外科醫生"],"oddIndex":2,"groupingRule":"除教師外都是醫療專業人員（教師屬於教育行業）"},
  {"id":"ooo_m17","difficulty":"medium","items":["影子","回聲","倒影","照片","海市蜃樓"],"oddIndex":3,"groupingRule":"除照片外都是源消失就會消失的臨時再現（照片是永久記錄）"},
  {"id":"ooo_m18","difficulty":"medium","items":["手套","襪子","戒指","鞋","靴子"],"oddIndex":2,"groupingRule":"除戒指外都是穿在手腳上的衣物（戒指是首飾不是衣物）"},
  {"id":"ooo_m19","difficulty":"medium","items":["鹽","糖","胡椒","麵粉","肉桂"],"oddIndex":3,"groupingRule":"除麵粉外都是調味料或香料（麵粉是烘焙原料）"},
  {"id":"ooo_m20","difficulty":"medium","items":["羽毛","氣球","煙","錨","泡泡"],"oddIndex":3,"groupingRule":"除錨以外都是輕的、能浮起的東西（錨很重會下沉）"},
  {"id":"ooo_m21","difficulty":"medium","items":["刀","剪刀","鋸","錘子","剃刀"],"oddIndex":3,"groupingRule":"除錘子外都是切割工具（錘子是敲打工具）"},
  {"id":"ooo_m22","difficulty":"medium","items":["河流","溪流","湖泊","瀑布","池塘"],"oddIndex":3,"groupingRule":"除瀑布外都有水平的水面（瀑布是垂直流水）"},

  {"id":"ooo_h01","difficulty":"hard","items":["心","承諾","記錄","沉默","波浪","冰"],"oddIndex":2,"groupingRule":"都能被「打破」的事物（打破沉默、打破心、打破波浪、打破冰）除外是記錄（記錄是「打破」但意為超越／刷新）"},
  {"id":"ooo_h02","difficulty":"hard","items":["河流","鼻子","故事","時鐘","絲襪","談話"],"oddIndex":3,"groupingRule":"都能「跑」的事物（河流奔跑、鼻子流涕、故事發展、絲襪抽絲、談話進行）除外是時鐘（時鐘是「滴答」走的）"},
  {"id":"ooo_h03","difficulty":"hard","items":["馬鈴薯","電池","雲","想法","沙發","閃電"],"oddIndex":4,"groupingRule":"都與「電」或「能量」有關的事物除外是沙發（沙發沒有電荷關聯）"},
  {"id":"ooo_h04","difficulty":"hard","items":["鏡子","湖","地板","眼睛","鑽石","盾牌"],"oddIndex":2,"groupingRule":"都有反射面的事物除外是地板（地板通常不反光）"},
  {"id":"ooo_h05","difficulty":"hard","items":["郵票","護照","車票","硬幣","信","書籤"],"oddIndex":5,"groupingRule":"都用於旅行或交易的事物除外是書籤（書籤用於閱讀）"},
  {"id":"ooo_h06","difficulty":"hard","items":["梯子","事業","山","溫度","樓梯","電梯"],"oddIndex":5,"groupingRule":"都是逐步攀升的事物除外是電梯（電梯無需逐步就能上升）"},
  {"id":"ooo_h07","difficulty":"hard","items":["蠟燭","電池","儲蓄","耐心","繩子","引線"],"oddIndex":4,"groupingRule":"都能「耗盡」的事物除外是繩子（繩子磨損或斷裂，但不耗盡）"},
  {"id":"ooo_h08","difficulty":"hard","items":["橋","牙齒","空隙","沉默","柵欄","牆"],"oddIndex":4,"groupingRule":"都能被「填補」的事物除外是柵欄（柵欄圍合但不填補）"},
  {"id":"ooo_h09","difficulty":"hard","items":["謠言","火","疾病","油漆","奶油","新聞"],"oddIndex":3,"groupingRule":"都能自發「傳播」的事物除外是油漆（油漆是被塗抹的，不自發擴散）"},
  {"id":"ooo_h10","difficulty":"hard","items":["雞蛋","秘密","密碼","黎明","保險箱","核桃"],"oddIndex":3,"groupingRule":"都能被「破解」的事物除外是黎明（黎明是「破曉」，不是被破解）"},
  {"id":"ooo_h11","difficulty":"hard","items":["鐘","鼓","警報","雷","哨子","枕頭"],"oddIndex":5,"groupingRule":"都發出響亮聲音的事物除外是枕頭（枕頭柔軟無聲）"},
  {"id":"ooo_h12","difficulty":"hard","items":["鑰匙","密碼","門","地圖","線索","謎語"],"oddIndex":3,"groupingRule":"都能「打開」某物的事物除外是地圖（地圖引導方向但不打開什麼）"},
  {"id":"ooo_h13","difficulty":"hard","items":["種子","想法","謠言","水晶","投資","孩子"],"oddIndex":3,"groupingRule":"都能「成長」的事物除外是水晶（水晶是「形成」的，日常不說「成長」）"},
  {"id":"ooo_h14","difficulty":"hard","items":["線","情節","河流","爭論","耐心","路"],"oddIndex":4,"groupingRule":"都能被「追蹤」的事物除外是耐心（耐心是磨練的，不是追蹤的）"},
  {"id":"ooo_h15","difficulty":"hard","items":["風","笑話","發條","手錶","膠帶","時鐘"],"oddIndex":1,"groupingRule":"都能被「上緊／捲起」的事物除外是笑話（笑話是講的，不是捲的）"},
  {"id":"ooo_h16","difficulty":"hard","items":["玻璃","心","規則","記錄","雞蛋","承諾"],"oddIndex":2,"groupingRule":"都是易碎的事物除外是規則（規則被「打破」但本身不脆弱）"},
  {"id":"ooo_h17","difficulty":"hard","items":["雪","霧","塵","寂靜","黑暗","毯子"],"oddIndex":5,"groupingRule":"都是籠罩一片區域的無形現象除外是毯子（毯子是有形的織物）"},
  {"id":"ooo_h18","difficulty":"hard","items":["錨","根","傳統","基礎","習慣","風箏"],"oddIndex":5,"groupingRule":"都是使事物穩定的除外是風箏（風箏是飛走的）"},
  {"id":"ooo_h19","difficulty":"hard","items":["海綿","學生","土壤","心靈","紙","鏡子"],"oddIndex":5,"groupingRule":"都能「吸收」的事物除外是鏡子（鏡子反射而不吸收）"},
  {"id":"ooo_h20","difficulty":"hard","items":["火山","脾氣","氣球","泡泡","煙火","種子"],"oddIndex":5,"groupingRule":"都能「爆發」的事物除外是種子（種子發芽但不爆發）"},
  {"id":"ooo_h21","difficulty":"hard","items":["網","蛛網","陷阱","迷宮","拼圖","橋"],"oddIndex":5,"groupingRule":"都用於捕捉或使人困惑的事物除外是橋（橋連接而不困住）"},
  {"id":"ooo_h22","difficulty":"hard","items":["潮汐","時尚","命運","心情","季節","磚"],"oddIndex":5,"groupingRule":"都是週期性變化的事物除外是磚（磚是靜態不變的）"}
