[
  {"id":"ooo_e01","difficulty":"easy","items":["蘋果","香蕉","胡蘿蔔","葡萄"],"oddIndex":2,"groupingRule":"除胡蘿蔔外都是水果（胡蘿蔔是蔬菜）"},
  {"id":"ooo_e02","difficulty":"easy","items":["狗","貓","鯊魚","兔子"],"oddIndex":2,"groupingRule":"除鯊魚外都是陸地動物（鯊魚生活在水中）"},
